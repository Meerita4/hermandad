---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Hermanos-Hdad Santa Ángela">
  <main style="padding:4rem; max-width:900px; margin:0 auto">
    <h1>Hermanos</h1>
    <p>Listado de hermanos de la hermandad.</p>
    <p>
<a href="/hermanos.pdf" download class="download-btn">
        📥 Descargar hermanos (PDF)
      </a>
    </p>
    
<h2>Visor de Hermanos</h2>
    <div class="pdf-container">
      <iframe src="/hermanos.pdf" title="Hermanos de la Hermandad"></iframe>
    </div>
  </main>
</Layout>

<style>
  .download-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: #8B0000;
    color: white;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    transition: background-color 0.3s;
  }
  
  .download-btn:hover {
    background-color: #5c0000;
  }
  
  .pdf-container {
    margin-top: 1.5rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .pdf-container iframe {
    width: 100%;
    height: 80vh;
    border: none;
  }
</style>
