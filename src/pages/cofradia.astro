    font-family: 'Cinzel', serif;
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    color: #333;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .cofradia-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .cofradia-section:last-child {
    border-bottom: none;
  }

  .cofradia-section h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    color: #800020;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .cofradia-section p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 0.75rem;
    text-align: justify;
  }

  .cofradia-section strong {
    color: #800020;
  }

  @media (max-width: 768px) {
