---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Hermandad - Contacto">
  <Header />
  
  <main>
    <section class="contact">
      <h1>Contacto</h1>
      <p class="subtitle">¿Tienes alguna pregunta? Escríbenos</p>

      <form class="contact-form">
        <div class="form-group">
          <label for="name">Nombre</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn">Enviar mensaje</button>
      </form>

      <div class="contact-info">
        <div class="info-item">
          <span class="icon">📍</span>
          <p>Calle Principal 123, Ciudad</p>
        </div>
        <div class="info-item">
          <span class="icon">📧</span>
          <p>info@hermandad.com</p>
        </div>
        <div class="info-item">
          <span class="icon">📞</span>
          <p>+34 123 456 789</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    min-height: 100vh;
    padding-top: 100px;
  }

  .contact {
    max-width: 600px;
    margin: 0 auto;
    padding: 4rem 2rem;
    text-align: center;
  }

  h1 {
    font-family: 'Cinzel', serif;
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #8B0000;
  }

  .subtitle {
    color: #666;
    margin-bottom: 3rem;
  }

  .contact-form {
    background: #f9f9f9;
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
    text-align: left;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    color: #333;
    font-weight: 500;
  }

  input, textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #ddd;
    border-radius: 10px;
    background: #fff;
    color: #333;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: #8B0000;
  }

  textarea {
    resize: vertical;
  }

  .btn {
    width: 100%;
    padding: 1rem;
    background: #8B0000;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background: #5c0000;
    transform: translateY(-2px);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .info-item .icon {
    font-size: 1.5rem;
  }

  @media (max-width: 768px) {
    main {
      padding-top: 80px;
    }

    .contact {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .contact-form {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    main {
      padding-top: 70px;
    }

    .contact {
      padding: 1.5rem 0.75rem;
    }

    h1 {
      font-size: 1.6rem;
    }

    .contact-form {
      padding: 1rem;
      border-radius: 12px;
    }

    .btn {
      padding: 0.875rem;
    }
  }

  .info-item p {
    color: #555;
  }
</style>
