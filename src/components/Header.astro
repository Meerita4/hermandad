---
import escudo from '../images/escudo.png';

const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Hermandad', href: '/hermandad' },
  { name: 'Titulares', href: '/titulares' },
  { name: 'Cofradía', href: '/cofradia' },
  { name: 'Hermanos', href: '/hermanos' },
  { name: 'Cultos', href: '/cultos' },
  { name: 'Enseres', href: '/enseres' },
];
---

<header>
  <nav class="nav-wrap">
    <div class="logo">
      <a href="/">
        <img src={escudo.src} alt="Escudo" class="logo-img" />
        HERMANDAD SACRAMENTAL DE SANTA ÁNGELA
      </a>
    </div>

    <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false">☰</button>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a href={item.href}>{item.name}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script type="module">
  if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.querySelector('.menu-toggle');
      const links = document.querySelector('.nav-links');
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        links.classList.toggle('open');
      });

      // marcar enlace activo
      const anchors = document.querySelectorAll('.nav-links a');
      const path = location.pathname.replace(/\\/g, '/');
      anchors.forEach((a) => {
        const href = a.getAttribute('href');
        if (href === path || (href !== '/' && path.startsWith(href))) {
          a.classList.add('active');
        }
      });
    });
  }
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #ffffff;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .nav-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
    gap: 2rem;
  }

  .logo {
    flex-shrink: 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #111111;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .logo-text {
    display: block;
  }

  .logo-img {
    height: 45px;
    width: auto;
    flex-shrink: 0;
    border-radius: 4px;
  }

  .menu-toggle {
    display: none;
    background: transparent;
    border: none;
    color: #111111;
    font-size: 1.4rem;
    cursor: pointer;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    color: #111111;
    transition: color 0.2s ease, transform 0.15s ease;
    padding: 0.25rem 0.35rem;
  }

  .nav-links a:hover {
    color: #800020;
    transform: translateY(-1px);
  }

  .nav-links a.active {
    color: #e94560;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .logo a {
      font-size: 0.95rem;
    }

    .logo-img {
      height: 40px;
    }
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: block;
    }

    .nav-links {
      position: absolute;
      top: 64px;
      right: 0;
      background: #ffffff;
      flex-direction: column;
      padding: 1rem 1.25rem;
      gap: 0.5rem;
      border-left: 1px solid rgba(0,0,0,0.1);
      box-shadow: -2px 4px 8px rgba(0,0,0,0.1);
      transform-origin: top right;
      display: none;
      min-width: 180px;
    }

    .nav-links.open {
      display: flex;
    }
  }

  @media (max-width: 768px) {
    .nav-wrap {
      padding: 0.5rem 1rem;
    }

    .logo a {
      font-size: 0.85rem;
      gap: 0.5rem;
    }

    .logo-img {
      height: 38px;
    }
  }

  @media (max-width: 480px) {
    .nav-wrap {
      padding: 0.5rem 0.75rem;
    }

    .logo a {
      font-size: 0.75rem;
      gap: 0.4rem;
      max-width: 240px;
      line-height: 1.15;
    }

    .logo-img {
      height: 32px;
    }

    .menu-toggle {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 360px) {
    .logo a {
      font-size: 0.65rem;
      max-width: 190px;
    }

    .logo-img {
      height: 28px;
    }
  }
</style>
