---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h3>Hermandad Sacramental</h3>
      <p>Santísimo Cristo del Amor y Humildad ante Caifás, María Santísima de la Salud y Esperanza, Santa Ángela de la Cruz y San Antonio Abad</p>
    </div>

    <div class="footer-section">
      <h3>Contacto</h3>
      <p><strong>Parroquia:</strong> Parroquia de Santa Angela de la Cruz y San Antonio Abad</p>
      <p><strong>Dirección:</strong> Av. de Madrid, 11540 Sanlúcar de Barrameda, Cádiz</p>
      <p><strong>Email:</strong> cristoamoryhumildad@gmail.com</p>
    </div>

    <div class="footer-section">
      <h3>Síguenos</h3>
      <div class="social-links">
        <a href="https://www.facebook.com/agrupaciondeSantaAngela" target="_blank" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="https://www.instagram.com/hermandaddesantaangela" target="_blank" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://x.com/amoryhumildad1" target="_blank" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
        </a>
      </div>
    </div>

    <div class="footer-section">
      <h3>Enlaces</h3>
      <ul class="footer-links">
        <li><a href="/hermandad">Hermandad</a></li>
        <li><a href="/titulares">Titulares</a></li>
        <li><a href="/cofradia">Cofradía</a></li>
        <li><a href="/cultos">Cultos</a></li>
        <li><a href="/hermanos">Hermanos</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {currentYear} Hermandad Sacramental de Santa Ángela de la Cruz. Todos los derechos reservados.</p>
    <p class="creditos">Web diseñada por Alejandro Rodríguez Mera</p>
  </div>
</footer>

<style>
  footer {
    background:#440E03;
    color: #ffffff;
    padding: 3rem 1.5rem 1.5rem;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .footer-section h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: #ffffff;
    margin-bottom: 1rem;
    border-bottom: 2px solid #800020;
    padding-bottom: 0.5rem;
  }

  .footer-section p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #cccccc;
    margin-bottom: 0.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .social-links a {
    color: #ffffff;
    transition: color 0.3s, transform 0.3s;
  }

  .social-links a:hover {
    color: #800020;
    transform: scale(1.2);
  }

  .footer-links {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: #cccccc;
    font-size: 0.95rem;
    transition: color 0.3s;
  }

  .footer-links a:hover {
    color: #800020;
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid #333333;
    text-align: center;
  }

  .footer-bottom p {
    color: #888888;
    font-size: 0.9rem;
  }

  .footer-bottom .creditos {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: #666666;
  }

  @media (max-width: 768px) {
    footer {
      padding: 2rem 1rem 1rem;
    }

    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }

    .footer-section h3 {
      font-size: 1.1rem;
    }

    .footer-section p {
      font-size: 0.9rem;
    }

    .social-links {
      justify-content: center;
    }

    .footer-links a {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: 1.5rem 0.75rem 1rem;
    }

    .footer-section h3 {
      font-size: 1rem;
      margin-bottom: 0.75rem;
    }

    .footer-section p {
      font-size: 0.85rem;
    }

    .footer-bottom p {
      font-size: 0.8rem;
    }

    .footer-bottom .creditos {
      font-size: 0.75rem;
    }
  }
</style>
